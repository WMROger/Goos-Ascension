  m_text: "\"<b>\u2014 CONTROLS \u2014</b>\\n\\n\" +\r\n        \"<b>A / D</b>         
    Move Left / Right\\n\" +\r\n        \"<b>Space</b>       Jump\\n\" +\r\n       
    \"<b>Left Shift</b>  Dash\\n\" +\r\n        \"<b>E</b>               Transform 
    <size=70%>(Slime \u2194 Human)</size>\\n\\n\" +\r\n        \"<b>\u2014 COMBAT
    \u2014</b>\\n\\n\" +\r\n        \"<b>Q</b>               Switch Weapon  <size=70%>(Sword
    / Gun)</size>\\n\" +\r\n        \"<b>Left Click</b>  Attack / Shoot\\n\" +\r\n       
    \"<b>Hold Click</b> Charge Attack / Charged Shot\\n\\n\" +\r\n        \"<b>\u2014
    MENU \u2014</b>\\n\\n\" +\r\n        \"<b>Escape</b>      Open Settings\";"
